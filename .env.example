# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.

# ── LINE LIFF ──────────────────────────────────────────────
# Set to true to skip LINE auth in browser (mock profile used)
NEXT_PUBLIC_LIFF_MOCK=true

# Your LIFF App ID from LINE Developer Console
# https://developers.line.biz/console/
NEXT_PUBLIC_LIFF_ID=

# Public URL of your LIFF app (used for redirects)
NEXT_PUBLIC_LIFF_URL=

# ── LINE Messaging API ─────────────────────────────────────
# Channel Access Token from LINE Developer Console
LINE_CHANNEL_ACCESS_TOKEN=

# ── Backend API ────────────────────────────────────────────
# Base URL of the PayDay+ backend (NestJS)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# (Optional) Hard-code a company ID for single-tenant setups
# NEXT_PUBLIC_COMPANY_ID=
